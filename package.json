{
  "name": "po18-upload-sidecar",
  "version": "1.0.0",
  "private": true,
  "main": "server-pg.js",
  "scripts": {
    "start": "node server-pg.js",
    "status": "node docker/status-check.js local",
    "bot": "node bot/telegram-bot.js",
    "admin:dev": "npm --prefix admin-ui run dev",
    "admin:build": "npm --prefix admin-ui run build && node scripts/publish-admin-ui.mjs",
    "test": "node --test \"tests/*.test.js\"",
    "test:smoke": "playwright test --config=playwright.config.js",
    "test:pg": "node scripts/run-pg-integration.js",
    "check:context": "node scripts/check-build-context.js",
    "db:rollback": "node scripts/migrate-rollback.js",
    "audit:prod": "npm audit --omit=dev",
    "docker:build": "docker build --provenance=false --target app -t wenmoux/reader:v1.0 .",
    "docker:push": "docker push wenmoux/reader:v1.0"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "node-html-parser": "^7.0.1",
    "pg": "^8.20.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
