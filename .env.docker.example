# Same shape as .env.example; kept as an explicit Docker template.
POSTGRES_DB=po18
POSTGRES_USER=po18
POSTGRES_PASSWORD=change-this-postgres-password
PO18_PG_URL=postgres://po18:change-this-postgres-password@postgres:5432/po18

PO18_UPLOAD_ADMIN_USER=admin
PO18_UPLOAD_ADMIN_PASSWORD=change-this-admin-password
PO18_UPLOAD_SESSION_SECRET=change-this-long-random-secret
PO18_UPLOAD_API_TOKEN=change-this-random-upload-api-token
PO18_METRICS_TOKEN=

PO18_BOT_API_TOKEN=change-this-random-bot-api-token
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_REQUEST_TIMEOUT_MS=60000

PO18_SHARE_API_URL=http://127.0.0.1:3200
PIKPAK_WEBDAV_URL=
PIKPAK_WEBDAV_USERNAME=
PIKPAK_WEBDAV_PASSWORD=
PIKPAK_WEBDAV_ROOT=/
