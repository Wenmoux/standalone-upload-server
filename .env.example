# Copy to .env before running docker compose.
# Replace every change-this value before exposing the service publicly.

POSTGRES_DB=po18
POSTGRES_USER=po18
POSTGRES_PASSWORD=change-this-postgres-password

# Docker internal database URL. For a database outside Docker, replace postgres with the host name/IP.
PO18_PG_URL=postgres://po18:change-this-postgres-password@postgres:5432/po18

PO18_UPLOAD_HOST=0.0.0.0
PO18_UPLOAD_PORT=3100
PO18_UPLOAD_ADMIN_USER=admin
PO18_UPLOAD_ADMIN_PASSWORD=change-this-admin-password
PO18_UPLOAD_SESSION_SECRET=change-this-long-random-secret
PO18_UPLOAD_API_TOKEN=change-this-random-upload-api-token
PO18_METRICS_TOKEN=

PO18_READER_HOST=0.0.0.0
PO18_READER_PORT=3200
PO18_API_BASE=http://server-pg:3100

PO18_SERVER_URL=http://server-pg:3100
PO18_SHARE_API_URL=http://127.0.0.1:3200
PO18_BOT_API_TOKEN=change-this-random-bot-api-token
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_REQUEST_TIMEOUT_MS=60000
BOT_HEALTH_HOST=0.0.0.0
BOT_HEALTH_PORT=3300

# Optional bot export target.
PIKPAK_WEBDAV_URL=
PIKPAK_WEBDAV_USERNAME=
PIKPAK_WEBDAV_PASSWORD=
PIKPAK_WEBDAV_ROOT=/

# Optional one-off migration input.
# OLD_TELEGRAM_USERS_DB=/absolute/path/to/users.db
